# 知薪 (KSTAR) Backend Configuration
# Copy this to .env and fill in your values

# 数据库已本地化（SQLite），无需 Supabase 密钥
# 数据库文件自动创建在 backend/data/zhixin.db

# LLM Provider (deepseek | spark | openai | groq)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# KSTAR Parameters
PASS_THRESHOLD=0.80
MAX_CYCLES=2
REVIEW_PASS_THRESHOLD=0.67

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
